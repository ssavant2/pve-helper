FROM nginx:alpine@sha256:7068961d45b07b2af510ac002e9daa63a1d3eba2111202d6768798690800fffd

LABEL org.opencontainers.image.source="https://github.com/ssavant2/pve-helper" \
      org.opencontainers.image.licenses="AGPL-3.0-only"

COPY docker/nginx/templates/default.conf.template /etc/nginx/templates/default.conf.template
COPY docker/nginx/15-storage-accel-manifest.sh /docker-entrypoint.d/15-storage-accel-manifest.sh
COPY LICENSE /usr/share/licenses/pve-helper/LICENSE
