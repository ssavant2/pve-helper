# Core app
APP_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=false
APP_REQUIRE_LOGIN=true
# Canonical external URL used for OIDC/logout callbacks. The app header displays
# the actual request URL, so this mainly needs to match your Authentik provider.
APP_BASE_URL=https://pve-helper.example.com
ALLOWED_HOSTS=pve-helper.example.com,dockerhost,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://pve-helper.example.com,http://dockerhost:21080,http://localhost:21080
USE_X_FORWARDED_HOST=true
SECURE_PROXY_SSL_HEADER=true
APP_PORT=21080
TZ=UTC
# Optional: IP/CIDR of a reverse proxy (such as Nginx Proxy Manager) in front
# of this app. See docs/deployment-runbook.md before setting this.
NGINX_TRUSTED_PROXY=127.0.0.1

# Database
DB_NAME=pve_helper
DB_ADMIN_USER=pve_helper_admin
DB_ADMIN_PASSWORD=replace-with-db-admin-password
DB_USER=pve_helper
DB_PASSWORD=replace-with-db-password
DB_HOST=db
DB_PORT=5432

# Authentik OIDC
# For an internal-only deployment, point OIDC_ISSUER_URL at the INTERNAL Authentik URL
# that fully serves the flow UI (e.g. an internal-CA-signed hostname). The OP endpoints
# (authorize/token/userinfo/jwks) are derived from this issuer automatically.
OIDC_ISSUER_URL=https://auth.example.com/application/o/pve-helper/
OIDC_CLIENT_ID=replace-from-authentik
OIDC_CLIENT_SECRET=replace-from-authentik
OIDC_REDIRECT_URI=https://pve-helper.example.com/auth/oidc/callback
OIDC_REQUIRED_GROUP=pve-helper-admins
OIDC_SCOPES=openid profile email groups

# Internal CA trust for back-channel TLS.
# The app makes server-to-server calls (OIDC token/JWKS, and Proxmox) over HTTPS. If those
# hosts use an internal/private CA, the container must trust it or those calls fail with
# SSLError. Mount a PEM bundle (public roots + your internal CA) into the container and set
# this to its path. Leave empty if your IdP and Proxmox use publicly-trusted certificates.
# Example container path when mounting a bundle: /etc/ssl/pve-helper-ca-bundle.pem
REQUESTS_CA_BUNDLE=

# Proxmox API
PVE_ENDPOINTS=https://pve-node-1.example.com:8006
PVE_VERIFY_TLS=true
PVE_CA_BUNDLE=
PVE_API_TOKEN_ID=replace-with-token-id
PVE_API_TOKEN_SECRET=replace-with-token-secret
BACKUP_INTEGRATION_API_ENABLED=false
BACKUP_POLICY_TAG_PREFIX=backup-
# Scheduled VM/CT power actions are enabled by default. Set this to false if
# you want to disable them even when the token has HelperPower permissions.
SCHEDULED_ACTIONS_ENABLED=true
SCHEDULED_ACTION_TIMEOUT_SECONDS=1800
# Backups/restores are allowed a longer task timeout (default: 6 hours).
BACKUP_TASK_TIMEOUT_SECONDS=21600
SCHEDULED_ACTION_POLL_INTERVAL_SECONDS=5
SCHEDULED_ACTION_RUN_RETENTION_DAYS=90
# Django-Q control plane (schedules/retention/reapers) and bulk data plane.
# Keep Q_BULK_RETRY greater than Q_BULK_TIMEOUT to prevent duplicate long jobs.
# Q_BULK_WORKERS is a process count, not a core count: bulk work is mostly
# I/O-bound (Proxmox does the disk work; the worker sleeps in wait_for_task), so
# 2 bulk workers run fine on a single core. See docs/deployment-runbook.md.
Q_CLUSTER_WORKERS=1
Q_CLUSTER_TIMEOUT=1800
Q_CLUSTER_RETRY=2100
Q_BULK_WORKERS=2
Q_BULK_TIMEOUT=21600
Q_BULK_RETRY=22200
# A scan still running after this limit plus a 15-minute grace period is
# reconciled as failed so it cannot block later scans.
SCAN_TASK_TIMEOUT_SECONDS=21600
# Integrated VM console. Requires VM.Console on the Proxmox token.
CONSOLE_ENABLED=true
CONSOLE_SESSION_TTL_SECONDS=30
CONSOLE_CONNECT_TIMEOUT_SECONDS=10
CONSOLE_SESSION_RETENTION_HOURS=24

# Storage mount placeholders. The example splits general file/ISO/backup-style
# storage (`nfs-fs`, often capacity/spinning disk) from VM disk storage
# (`nfs-vm`, often SSD). Use whatever names and layout match your Proxmox setup.
TRUENAS_FS_HOST_PATH=/mnt/pve-helper/truenas-fs
TRUENAS_VM_HOST_PATH=/mnt/pve-helper/truenas-vm
TRUENAS_FS_CONTAINER_PATH=/storages/truenas-fs
TRUENAS_VM_CONTAINER_PATH=/storages/truenas-vm
TRUENAS_FS_EXPORT=nfs-server.example.com:/export/proxmox-fs
TRUENAS_VM_EXPORT=nfs-server.example.com:/export/proxmox-vm
TRUENAS_FS_STORAGE_ID=nfs-fs
TRUENAS_VM_STORAGE_ID=nfs-vm
PVE_EXPECTED_CONSUMERS=pve-node-1
STORAGE_WRITE_ENABLED=true
# 0 means no app-level upload size limit. Use a positive value to enforce a limit.
STORAGE_UPLOAD_MAX_SIZE_MB=0
# Django stores multipart upload chunks here before the view writes the final file.
# For large datastore uploads this must be on real storage, not container /tmp tmpfs.
FILE_UPLOAD_TEMP_DIR=/storages/truenas-fs/.pve-helper-upload-tmp
STORAGE_IMAGE_INFO_ENABLED=true
STORAGE_IMAGE_INFO_TIMEOUT_SECONDS=15
STORAGE_INFLATE_TIMEOUT_SECONDS=14400
# Serve authorized downloads through the internal nginx sidecar instead of
# streaming file bytes through Django/Gunicorn. Set false to use the Django fallback.
STORAGE_DOWNLOAD_ACCEL_ENABLED=true
STORAGE_DOWNLOAD_ACCEL_PREFIX=/_pve_helper_download
# Nginx front/sidecar settings for large uploads/downloads.
NGINX_CLIENT_MAX_BODY_SIZE=0
NGINX_PROXY_READ_TIMEOUT=86400s
NGINX_PROXY_SEND_TIMEOUT=86400s
NGINX_SEND_TIMEOUT=86400s
# Large datastore downloads can keep a Gunicorn worker busy for a long time.
# These still apply to ordinary app requests and to fallback Django downloads.
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=86400

# Django Q2
Q_CLUSTER_WORKERS=1
Q_CLUSTER_TIMEOUT=1800
Q_CLUSTER_RETRY=2100
