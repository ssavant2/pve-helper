# Core app
APP_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=false
APP_REQUIRE_LOGIN=true
APP_BASE_URL=https://pve-helper.example.com
ALLOWED_HOSTS=pve-helper.example.com,dockerhost,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://pve-helper.example.com,http://dockerhost:21080,http://localhost:21080
USE_X_FORWARDED_HOST=true
SECURE_PROXY_SSL_HEADER=true
APP_PORT=21080
TZ=UTC

# Database
DB_NAME=pve_helper
DB_USER=pve_helper
DB_PASSWORD=replace-with-db-password
DB_HOST=db
DB_PORT=5432

# Authentik OIDC
# For an internal-only deployment, point OIDC_ISSUER_URL at the INTERNAL Authentik URL
# that fully serves the flow UI (e.g. an internal-CA-signed hostname). The OP endpoints
# (authorize/token/userinfo/jwks) are derived from this issuer automatically.
OIDC_ISSUER_URL=https://authentik.example.internal/application/o/pve-helper/
OIDC_CLIENT_ID=replace-from-authentik
OIDC_CLIENT_SECRET=replace-from-authentik
OIDC_REDIRECT_URI=https://pve-helper.example.com/auth/oidc/callback
OIDC_REQUIRED_GROUP=pve-helper-admins
OIDC_SCOPES=openid profile email groups

# Internal CA trust for back-channel TLS.
# The app makes server-to-server calls (OIDC token/JWKS, and Proxmox) over HTTPS. If those
# hosts use an internal/private CA, the container must trust it or those calls fail with
# SSLError. Mount a PEM bundle (public roots + your internal CA) into the container and set
# this to its path. Leave empty if your IdP and Proxmox use publicly-trusted certificates.
# Example container path when mounting a bundle: /etc/ssl/pve-helper-ca-bundle.pem
REQUESTS_CA_BUNDLE=

# Proxmox API
PVE_ENDPOINTS=https://pve1.example.com:8006
PVE_VERIFY_TLS=true
PVE_CA_BUNDLE=
PVE_API_TOKEN_ID=replace-with-token-id
PVE_API_TOKEN_SECRET=replace-with-token-secret

# Storage mount placeholders. For production, point these at host-mounted NFS paths.
TRUENAS_FS_HOST_PATH=/mnt/pve-helper/truenas-fs
TRUENAS_VM_HOST_PATH=/mnt/pve-helper/truenas-vm
TRUENAS_FS_STORAGE_ID=replace-with-proxmox-storage-id
TRUENAS_VM_STORAGE_ID=replace-with-proxmox-storage-id
PVE_EXPECTED_CONSUMERS=pve1

# Django Q2
Q_CLUSTER_WORKERS=1
Q_CLUSTER_TIMEOUT=1800
Q_CLUSTER_RETRY=2100
